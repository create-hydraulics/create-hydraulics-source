{
	"multipart": [
		{
			"apply": { "model": "createhydraulics:block/hardened_iron_pipe_core" }
		},
		{
			"when": { "up": "true" },
			"apply": { "model": "createhydraulics:block/hardened_iron_pipe_arm_up" }
		},
		{
			"when": { "down": "true" },
			"apply": { "model": "createhydraulics:block/hardened_iron_pipe_arm_down" }
		},
		{
			"when": { "north": "true" },
			"apply": { "model": "createhydraulics:block/hardened_iron_pipe_arm_north" }
		},
		{
			"when": { "south": "true" },
			"apply": { "model": "createhydraulics:block/hardened_iron_pipe_arm_south" }
		},
		{
			"when": { "east": "true" },
			"apply": { "model": "createhydraulics:block/hardened_iron_pipe_arm_east" }
		},
		{
			"when": { "west": "true" },
			"apply": { "model": "createhydraulics:block/hardened_iron_pipe_arm_west" }
		}
	]
}
